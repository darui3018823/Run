<Window x:Class="Run.RunDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Run"
        SizeToContent="Height"
        Width="450"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{DynamicResource WindowBg}"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Grid Margin="12,12,12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: icon + description -->
        <DockPanel Grid.Row="0">
            <Image x:Name="RunIcon" Width="32" Height="32"
                   DockPanel.Dock="Left" Margin="0,2,10,0"
                   VerticalAlignment="Top" SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="Type the name of a program, folder, document, or Internet resource, and Windows will open it for you."
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}"
                       FontSize="12"/>
        </DockPanel>

        <!-- Open: label + ComboBox -->
        <DockPanel Grid.Row="2">
            <TextBlock Text="Open:" DockPanel.Dock="Left"
                       VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextBrush}"
                       FontSize="12"/>
            <ComboBox x:Name="CommandBox"
                      IsEditable="True"
                      FontSize="12"
                      Background="{DynamicResource InputBg}"
                      Foreground="{DynamicResource TextBrush}"
                      BorderBrush="{DynamicResource InputBorder}"
                      KeyDown="CommandBox_KeyDown"
                      PreviewKeyDown="CommandBox_PreviewKeyDown"/>
        </DockPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"      Width="80" Margin="0,0,6,0" Click="OK_Click"     IsDefault="True"/>
            <Button Content="Cancel"  Width="80" Margin="0,0,6,0" Click="Cancel_Click" IsCancel="True"/>
            <Button Content="Browse..." Width="90" Click="Browse_Click"/>
        </StackPanel>
    </Grid>
</Window>
